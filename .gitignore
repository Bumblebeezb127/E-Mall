# Compiled output
target/
out/
build/
*.class
*.jar
*.war
*.ear

# IDE - IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# IDE - Eclipse
.classpath
.project
.settings/
.factorypath
.springBeans

# IDE - VS Code
.vscode/

# IDE - NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Maven
.mvn/wrapper/maven-wrapper.jar
**/mvnw
**/mvnw.cmd

# Node / Frontend
easybuy-frontend/node_modules/
easybuy-frontend/dist/
easybuy-frontend/.vite/
easybuy-frontend/npm-debug.log*
easybuy-frontend/yarn-debug.log*
easybuy-frontend/yarn-error.log*
easybuy-frontend/pnpm-debug.log*
easybuy-frontend/.env
easybuy-frontend/.env.local
easybuy-frontend/.env.*.local

# Temporary files
*.tmp
*.bak
*.swp
*~
*.orig

# Maven local repo copies
.m2/

# IDE workspace caches
*.lck

# Project-specific: exclude local manual test script directory
# 与 src/ 对应的本地手动测试脚本目录 (项目无关)
# 但保留 test/results/ 目录用于 run-all-tests.bat 写日志
test/
!test/results/
test/results/*

# Project-specific: include generated documentation
# 保留 doc/ 下的 docx 文档 + images/ 配图, 排除生成它们的 Python 脚本
# (脚本是开发工具, 不随仓库发布; 文档是最终交付物, 随仓库发布)
doc/*.pyc
doc/__pycache__/
doc/generate_docs.py
doc/generate_diagrams.py
doc/*.tmp

# Project-specific: exclude local Python caches from scripts/
**/__pycache__/
*.pyc
*.pyo

# Project-specific: exclude local build outputs in scripts
scripts/*.tmp

# Project-specific: exclude JMeter result files (output of running jmx)
jmeter/results/
jmeter/*.jtl
jmeter/*.csv
jmeter/html/

# Project-specific: exclude local Spring Boot actuator dump files
*.heapdump

# Project-specific: exclude Microsoft Office temporary lock files
~*.docx
~*.xlsx
~*.pptx
~*.tmp
