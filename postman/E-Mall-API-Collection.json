						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('响应状态码为200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('返回成功标志code=200', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.code).to.eql(200);",
									"});",
									"",
									"pm.test('返回包含JWT Token', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('token');",
									"    pm.expect(jsonData.data.token).to.be.a('string');",
									"    pm.expect(jsonData.data.token.split('.').length).to.eql(3);",
									"});",
									"",
									"pm.test('返回包含userId', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data).to.have.property('id');",
									"});",
									"",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.data && jsonData.data.token) {",
									"        pm.collectionVariables.set('token', jsonData.data.token);",
									"        pm.collectionVariables.set('userId', jsonData.data.id);",
									"        console.log('Token已保存:', jsonData.data.token.substring(0, 50) + '...');",
									"        console.log('UserId已保存:', jsonData.data.id);",
									"    }",
